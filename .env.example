# ──────────────────────────────────────────────
# Resend – Envío de correos
# Regístrate gratis en: https://resend.com
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Correo desde el que se envían los emails
# Debe ser un dominio verificado en Resend (ej: hola@nizzharvargas.com)
RESEND_FROM_EMAIL=hola@nizzharvargas.com

# Correo de Nizzhar para recibir notificaciones de nuevos leads
NIZZHAR_EMAIL=nizzhar@example.com

# ──────────────────────────────────────────────
# Supabase – Base de datos de leads
# Regístrate gratis en: https://supabase.com
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
